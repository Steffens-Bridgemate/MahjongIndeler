@page "/members"
@using Tsump.Models
@using Tsump.Services
@inject MemberService MemberService
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.Get("Members") - Tsumo!</PageTitle>

<h1>@Lang.Get("ClubMembers")</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddForm">@Lang.Get("AddMember")</button>
</div>

@if (showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@(isEditing ? Lang.Get("EditMember") : Lang.Get("AddNewMember"))</h5>
            <EditForm Model="currentMember" OnValidSubmit="SaveMember">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">@Lang.Get("Name")</label>
                    <input class="form-control" value="@currentMember.Name" @oninput="OnNameInput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">@Lang.Get("Email")</label>
                    <InputText class="form-control" @bind-Value="currentMember.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label">@Lang.Get("Phone")</label>
                    <InputText class="form-control" @bind-Value="currentMember.Phone" />
                </div>
                <div class="mb-3">
                    <label class="form-label">@Lang.Get("ExtraThreePlayerTables")</label>
                    <InputNumber class="form-control" style="max-width: 120px;" @bind-Value="currentMember.ExtraThreePlayerTableCount" />
                    <small class="text-muted">@Lang.Get("ExtraThreePlayerTablesDesc")</small>
                </div>
                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="currentMember.IsActive" />
                    <label class="form-check-label">@Lang.Get("Active")</label>
                </div>
                <button type="submit" class="btn btn-success me-2">@Lang.Get("Save")</button>
                <button type="button" class="btn btn-secondary" @onclick="CancelForm">@Lang.Get("Cancel")</button>
            </EditForm>
        </div>
    </div>
}

@if (members == null)
{
    <p>@Lang.Get("Loading")</p>
}
else if (members.Count == 0)
{
    <p class="text-muted">@Lang.Get("NoMembersYet")</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th style="width: 50px;"></th>
                <th>@Lang.Get("Name")</th>
                <th>@Lang.Get("Email")</th>
                <th>@Lang.Get("Phone")</th>
                <th>@Lang.Get("Joined")</th>
                <th class="text-center">@Lang.Get("Active")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in members.OrderBy(m => m.Name))
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-1 member-actions">
                            <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center member-action-btn" title="@Lang.Get("Edit")" @onclick="() => EditMember(member)">&#9998;</button>
                            <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center @(deleteConfirmId == member.Id ? "member-action-btn-confirm" : "member-action-btn")"
                                    title="@(deleteConfirmId == member.Id ? Lang.Get("ConfirmDeletion") : Lang.Get("Remove"))"
                                    @onclick="() => DeleteClicked(member.Id)">&#x1F5D1;</button>
                        </div>
                    </td>
                    <td>@member.Name</td>
                    <td>@member.Email</td>
                    <td>@member.Phone</td>
                    <td>@member.JoinedDate.ToShortDateString()</td>
                    <td class="text-center">
                        @if (member.IsActive)
                        {
                            <span class="badge bg-success" style="font-size: 1em;">&check;</span>
                        }
                        else
                        {
                            <span class="badge bg-danger" style="font-size: 1em;">&times;</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">@Lang.Get("Total"): @members.Count @Lang.Get("members") (@members.Count(m => m.IsActive) @Lang.Get("active"))</p>
}

<style>
    .member-action-btn { width: 20px; height: 20px; }
    .member-action-btn-confirm { width: 26px; height: 26px; }
    .member-actions { flex-direction: column; }
    @@media (min-width: 768px) {
        .member-actions { flex-direction: row; }
    }
</style>

@code {
    private List<Member>? members;
    private Member currentMember = new();
    private bool showForm;
    private bool isEditing;
    private bool userLoweredFirst;
    private Guid? deleteConfirmId;

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            members = await MemberService.GetAllAsync();
            StateHasChanged();
        }
    }

    private void ShowAddForm()
    {
        currentMember = new Member();
        isEditing = false;
        showForm = true;
        userLoweredFirst = false;
        deleteConfirmId = null;
    }

    private void EditMember(Member member)
    {
        currentMember = new Member
        {
            Id = member.Id,
            Name = member.Name,
            Email = member.Email,
            Phone = member.Phone,
            JoinedDate = member.JoinedDate,
            IsActive = member.IsActive,
            ExtraThreePlayerTableCount = member.ExtraThreePlayerTableCount
        };
        isEditing = true;
        showForm = true;
        userLoweredFirst = member.Name.Length > 0 && char.IsLower(member.Name[0]);
        deleteConfirmId = null;
    }

    private async Task SaveMember()
    {
        if (string.IsNullOrWhiteSpace(currentMember.Name))
            return;

        if (isEditing)
            await MemberService.UpdateAsync(currentMember);
        else
            await MemberService.AddAsync(currentMember);

        members = await MemberService.GetAllAsync();
        showForm = false;
        deleteConfirmId = null;
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";

        if (value.Length == 1 && !userLoweredFirst)
        {
            // Auto-capitalize the first letter on initial typing
            value = value.ToUpper();
        }
        else if (value.Length >= 1 && char.IsLower(value[0]))
        {
            // User explicitly typed or changed first char to lowercase
            userLoweredFirst = true;
        }
        else if (value.Length >= 1 && char.IsUpper(value[0]))
        {
            userLoweredFirst = false;
        }

        currentMember.Name = value;
    }

    private void CancelForm()
    {
        showForm = false;
        deleteConfirmId = null;
    }

    private async Task DeleteClicked(Guid id)
    {
        if (deleteConfirmId == id)
        {
            await MemberService.DeleteAsync(id);
            members = await MemberService.GetAllAsync();
            deleteConfirmId = null;
        }
        else
        {
            deleteConfirmId = id;
        }
    }
}
