@page "/session"
@using Tsump.Models
@using Tsump.Services
@inject MemberService MemberService
@inject SessionService SessionService
@inject TableAssignmentService TableAssignmentService
@inject LanguageService Lang
@inject SettingsService SettingsService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject LocalStorageService Storage
@implements IDisposable

<PageTitle>@Lang.Get("WeeklySession") - Tsumo!</PageTitle>

<h1>@Lang.Get("WeeklySession")</h1>

<div class="row mb-3">
    <div class="col-auto">
        <label class="form-label"><strong>@Lang.Get("SessionDate")</strong></label>
        <input type="date" class="form-control" style="max-width: 250px;"
               value="@sessionDate.ToString("yyyy-MM-dd")"
               @onchange="OnDateChanged" />
    </div>
    <div class="col-auto">
        <label class="form-label"><strong>@Lang.Get("StartTime")</strong></label>
        <div class="d-flex align-items-center gap-1">
            <select class="form-select" style="max-width: 75px;"
                    value="@(hanchanStartTime.HasValue? hanchanStartTime.Value.Hours : -1)"
                    disabled="@IsLockedPastSession"
                    @onchange="OnHourChanged">
                <option value="-1">--</option>
                @for (int h = 0; h < 24; h++)
                {
                    var hh = h;
                    <option value="@hh">@hh.ToString("D2")</option>
                }
            </select>
            <span>:</span>
            <select class="form-select" style="max-width: 75px;"
                    value="@(hanchanStartTime.HasValue? hanchanStartTime.Value.Minutes : -1)"
                    disabled="@IsLockedPastSession"
                    @onchange="OnMinuteChanged">
                <option value="-1">--</option>
                @for (int m = 0; m < 60; m += 5)
                {
                    var mm = m;
                    <option value="@mm">@mm.ToString("D2")</option>
                }
            </select>
        </div>
    </div>
    <div class="col-auto d-flex align-items-end">
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox"
                   checked="@excludeFromOptimization"
                   disabled="@IsLockedPastSession"
                   @onchange="e => excludeFromOptimization = (bool)(e.Value ?? false)" />
            <label class="form-check-label">@Lang.Get("ExcludeFromOptimization")</label>
        </div>
    </div>
</div>

@if (hanchansOnDate.Count > 0)
{
    <div class="mb-3">
        <label class="form-label"><strong>@Lang.Get("SessionsOnDate")</strong></label>
        <div class="btn-group d-block" role="group">
            @foreach (var s in hanchansOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero))
            {
                var isActive = currentHanchan?.Id == s.Id;
                var sessionLabel = GetSessionLabel(s);
                <button class="btn btn-sm me-1 mb-1 @(isActive ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SelectHanchan(s)">
                    @sessionLabel
                </button>
            }
            <button class="btn btn-sm btn-outline-success me-1 mb-1" @onclick="StartNewHanchan"
                    disabled="@(currentHanchan != null && !currentHanchan.IsFinalized)">
                + @Lang.Get("NewSession")
            </button>
            @if (hanchansOnDate.Count(s => s.Tables.Count > 0) > 1)
            {
                @if (showExportAll)
                {
                    <button class="btn btn-sm btn-outline-secondary me-1 mb-1" @onclick="CopyAllHanchansToClipboard">
                        @(copiedAllToClipboard? Lang.Get("Copied") : Lang.Get("CopyToClipboard"))
                    </button>
                    <button class="btn btn-sm btn-outline-secondary me-1 mb-1" @onclick="OpenAllHanchans">
                        @Lang.Get("OpenPrint")
                    </button>
                    <button class="btn btn-sm btn-outline-secondary me-1 mb-1" @onclick="DownloadAllHanchans">
                        @Lang.Get("DownloadHtml")
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary me-1 mb-1" @onclick="() => showExportAll = true">
                        @Lang.Get("Export")
                    </button>
                }
            }
        </div>
    </div>
}

@if (IsLockedPastSession)
{
    <div class="alert alert-warning">
        @Lang.Get("PastSessionReadOnly")
    </div>
}

@if (members == null)
{
    <p>@Lang.Get("Loading")</p>
}
else if (members.Count == 0)
{
    <p class="text-muted">@Lang.Get("NoMembersRegistered") <a href="members">@Lang.Get("AddMembersLink")</a>.</p>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center" style="cursor: pointer;" @onclick="() => attendanceExpanded = !attendanceExpanded">
            <h5 class="mb-0 flex-grow-1">@Lang.Get("Attendance") (@presentIds.Count @Lang.Get("present") @Lang.Get("of") @activeMembers.Count @Lang.Get("active"))</h5>
            <span class="ms-2">@(attendanceExpanded ? "\u25B2" : "\u25BC")</span>
        </div>
        @if (attendanceExpanded)
        {
            <div class="card-body">
                @if (!IsLockedPastSession)
                {
                    <div class="mb-2">
                        <button class="btn btn-sm btn-outline-success me-1" @onclick="SelectAll">@Lang.Get("AllPresent")</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="SelectNone">@Lang.Get("AllAbsent")</button>
                    </div>
                }
                <div class="mb-3">
                    <input type="text" class="form-control" placeholder="@Lang.Get("SearchMembers")"
                           style="max-width: 300px; border-radius: 15px;"
                           @bind="searchText" @bind:event="oninput" />
                </div>
                <div class="row">
                    @foreach (var member in FilteredMembers())
                    {
                        <div class="col-md-4 col-sm-6 mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       checked="@presentIds.Contains(member.Id)"
                                       disabled="@IsLockedPastSession"
                                       @onchange="e => ToggleAttendance(member.Id, (bool)(e.Value ?? false))" />
                                <label class="form-check-label">@member.Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (!IsLockedPastSession)
    {
        <div class="mb-3">
            @if (showRegenerateConfirm)
            {
                <div class="alert alert-warning d-inline-block me-2">
                    @Lang.Get("RegenerateConfirm")
                    <button class="btn btn-sm btn-warning ms-2 me-1" @onclick="ConfirmRegenerate">@Lang.Get("YesRegenerate")</button>
                    <button class="btn btn-sm btn-secondary" @onclick="CancelRegenerate">@Lang.Get("Cancel")</button>
                </div>
            }
            else
            {
                <button class="btn btn-primary me-2" @onclick="GenerateTables" disabled="@(presentIds.Count < 3)">
                    @Lang.Get("GenerateTableAssignments")
                </button>
            }
            <button class="btn btn-success" @onclick="SaveHanchan" disabled="@(tables.Count == 0)">
                @Lang.Get("SaveHanchan")
            </button>
            @if (workflowStepIndex.HasValue)
            {
                <button class="btn @(saved ? "btn-primary" : "btn-outline-secondary") ms-2"
                        disabled="@(!saved)" @onclick="BackToWorkflow">
                    &larr; @Lang.Get("BackToWorkflow")
                </button>
                @if (!saved)
                {
                    <small class="text-muted ms-2">@Lang.Get("BackToWorkflowHint")</small>
                }
            }
            @if (currentHanchan != null)
            {
                @if (showDeleteConfirm)
                {
                    <span class="alert alert-danger d-inline-block ms-2 mb-0 py-1">
                        @Lang.Get("DeleteHanchanConfirm")
                        <button class="btn btn-sm btn-danger ms-2 me-1" @onclick="ConfirmDeleteHanchan">@Lang.Get("YesDelete")</button>
                        <button class="btn btn-sm btn-secondary" @onclick="CancelDeleteHanchan">@Lang.Get("Cancel")</button>
                    </span>
                }
                else
                {
                    <button class="btn btn-outline-danger ms-2" @onclick="RequestDeleteHanchan">
                        @Lang.Get("DeleteHanchan")
                    </button>
                }
            }
            @if (presentIds.Count < 3)
            {
                <span class="text-warning ms-2">@Lang.Get("NeedAtLeast3")</span>
            }
        </div>
    }

    @if (IsLockedPastSession && currentHanchan != null)
    {
        <div class="mb-3">
            @if (showDeleteConfirm)
            {
                <div class="alert alert-danger d-inline-block">
                    @Lang.Get("DeleteHanchanConfirm")
                    <button class="btn btn-sm btn-danger ms-2 me-1" @onclick="ConfirmDeleteHanchan">@Lang.Get("YesDelete")</button>
                    <button class="btn btn-sm btn-secondary" @onclick="CancelDeleteHanchan">@Lang.Get("Cancel")</button>
                </div>
            }
            else
            {
                <button class="btn btn-outline-danger" @onclick="RequestDeleteHanchan">
                    @Lang.Get("DeleteSession")
                </button>
            }
        </div>
    }

    @if (tables.Count > 0)
    {
        <div class="d-flex align-items-center mb-2 flex-wrap gap-1">
            <h4 class="mb-0">@Lang.Get("Hanchan") @GetCurrentHanchanHeader()</h4>
            @if (showExportSingle)
            {
                <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="CopyTablesToClipboard">
                    @(copiedToClipboard? Lang.Get("Copied") : Lang.Get("CopyToClipboard"))
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="OpenSingleHanchan">
                    @Lang.Get("OpenPrint")
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadSingleHanchan">
                    @Lang.Get("DownloadHtml")
                </button>
            }
            else
            {
                <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="() => showExportSingle = true">
                    @Lang.Get("Export")
                </button>
            }
        </div>

        @if (!IsLockedPastSession && selectedPlayerIds.Count > 0)
        {
            <div class="mb-3">
                <span class="text-muted me-2">
                    @Lang.Get("Selected"): @string.Join(", ", selectedPlayerIds.Select(id => GetPlayerName(id)))
                </span>
                @if (selectedPlayerIds.Count == 2)
                {
                    <button class="btn btn-sm btn-warning me-1" @onclick="SwapSelectedPlayers">
                        @Lang.Get("SwapPlayers")
                    </button>
                }
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearSelection">
                    @Lang.Get("ClearSelection")
                </button>
            </div>
        }

        <div class="row">
            @foreach (var table in tables)
            {
                <div class="col-md-4 mb-3">
                    <div class="card @(table.PlayerCount == 3 ? "border-warning" : "border-success")">
                        <div class="card-header @(table.PlayerCount == 3 ? "bg-warning text-dark" : "bg-success text-white")">
                            @Lang.Get("Table") @table.TableNumber (@table.PlayerCount @Lang.Get("players"))
                        </div>
                        <ul class="list-group list-group-flush">
                            @foreach (var playerId in table.PlayerIds)
                            {
                                var pid = playerId;
                                var player = members.FirstOrDefault(m => m.Id == pid);
                                var isSelected = selectedPlayerIds.Contains(pid);
                                <li class="list-group-item d-flex align-items-center @(isSelected ? "list-group-item-primary" : "")"
                                    style="cursor: @(IsLockedPastSession ? "default" : "grab")"
                                    draggable="@(!IsLockedPastSession)"
                                    @ondragstart="() => OnDragStart(pid)"
                                    @ondragover:preventDefault
                                    @ondrop="() => OnDrop(pid)"
                                    @onclick="() => OnPlayerClick(pid)">
                                    <span>@(player?.Name ?? Lang.Get("Unknown"))</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

        @if (presentIds.Count - tables.Sum(t => t.PlayerCount) > 0)
        {
            <div class="alert alert-info">
                @(presentIds.Count - tables.Sum(t => t.PlayerCount)) @Lang.Get("UnassignedPlayers")
            </div>
        }
    }

    @if (saved)
    {
        <div class="alert alert-success mt-3">@Lang.Get("SessionSaved")</div>
    }

}

@code {
    private List<Member>? members;
    private List<Member> activeMembers = new();
    private HashSet<Guid> presentIds = new();
    private List<TableAssignment> tables = new();
    private DateTime sessionDate = DateTime.Today;
    private TimeSpan? hanchanStartTime;
    private TimeSpan defaultStartTime;
    private bool saved;
    private string searchText = string.Empty;
    private bool showRegenerateConfirm;
    private bool showDeleteConfirm;
    private bool excludeFromOptimization;
    private bool attendanceExpanded = true;

    private List<Hanchan> hanchansOnDate = new();
    private Hanchan? currentHanchan;

    private List<Guid> selectedPlayerIds = new();
    private Guid? draggedPlayerId;
    private bool copiedToClipboard;
    private bool copiedAllToClipboard;
    private bool showExportSingle;
    private bool showExportAll;
    private int? workflowStepIndex;

    private bool IsLockedPastSession =>
        sessionDate.Date < DateTime.Today && currentHanchan is { IsFinalized: true };

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;

    private IEnumerable<Member> FilteredMembers()
    {
        var ordered = activeMembers.OrderBy(m => m.Name);
        if (string.IsNullOrWhiteSpace(searchText))
            return ordered;
        return ordered.Where(m => m.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Check if navigated from workflow
            var uri = new Uri(Nav.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            if (int.TryParse(query["fromWorkflow"], out var idx))
                workflowStepIndex = idx;

            var clubSettings = await SettingsService.GetAsync();
            defaultStartTime = clubSettings.DefaultStartTime;

            members = await MemberService.GetAllAsync();
            activeMembers = members.Where(m => m.IsActive).ToList();

            // Auto-set date/time to next scheduled slot if no session exists for today
            var nextSlot = await SettingsService.GetNextScheduledSlotAsync();
            if (nextSlot != null)
            {
                sessionDate = nextSlot.Value.Date;
                hanchanStartTime = nextSlot.Value.Time;
            }

            await LoadSessionsForDate();
            StateHasChanged();
        }
    }

    private async Task LoadSessionsForDate()
    {
        var allSessions = await SessionService.GetAllAsync();
        hanchansOnDate = allSessions.Where(s => s.Date.Date == sessionDate.Date).ToList();

        if (hanchansOnDate.Count > 0)
        {
            // Select the first session (by time) by default
            var first = hanchansOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero).First();
            LoadFromHanchan(first);
        }
        else
        {
            currentHanchan = null;
            excludeFromOptimization = false;
            // Set start time from schedule for this day, or fall back to default
            var settings = await SettingsService.GetAsync();
            var entry = settings.Schedule.FirstOrDefault(e => e.Day == sessionDate.DayOfWeek);
            hanchanStartTime = (entry != null && entry.StartTimes.Count > 0)
                ? entry.StartTimes.OrderBy(t => t).First()
                : defaultStartTime;
            presentIds.Clear();
            tables.Clear();
        }
        saved = false;
        showRegenerateConfirm = false;
    }

    private void LoadFromHanchan(Hanchan hanchan)
    {
        currentHanchan = hanchan;
        hanchanStartTime = hanchan.StartTime ?? defaultStartTime;
        presentIds = new HashSet<Guid>(hanchan.PresentMemberIds);
        tables = hanchan.Tables;
        excludeFromOptimization = hanchan.ExcludeFromOptimization;
        attendanceExpanded = !hanchan.IsFinalized;
        saved = false;
        showRegenerateConfirm = false;
    }

    private void SelectHanchan(Hanchan hanchan)
    {
        LoadFromHanchan(hanchan);
    }

    private async Task StartNewHanchan()
    {
        // Copy attendance from the last hanchan on this date
        var lastHanchan = hanchansOnDate
            .OrderByDescending(s => s.StartTime ?? TimeSpan.Zero)
            .FirstOrDefault();
        if (lastHanchan != null)
            presentIds = new HashSet<Guid>(lastHanchan.PresentMemberIds);
        else
            presentIds.Clear();

        currentHanchan = null;
        tables = new();
        excludeFromOptimization = false;
        attendanceExpanded = true;
        saved = false;
        showRegenerateConfirm = false;

        // Set start time: next scheduled time > previous hanchan + 1h > default
        ClubSettings? settings = await SettingsService.GetAsync();
        ScheduleEntry? entry = settings.Schedule.FirstOrDefault(e => e.Day == sessionDate.DayOfWeek);
        HashSet<TimeSpan> usedTimes = hanchansOnDate.Select(s => s.StartTime).Where(t => t.HasValue).Select(t => t!.Value).ToHashSet();
        TimeSpan? nextTime = entry?.StartTimes.OrderBy(t => t).Cast<TimeSpan?>().FirstOrDefault(t => !usedTimes.Contains(t!.Value));
        if (nextTime.HasValue)
        {
            hanchanStartTime = nextTime.Value;
        }
        else if (usedTimes.Any())
        {
            hanchanStartTime = usedTimes.Max().Add(TimeSpan.FromHours(1));
        }
        else
        {
            hanchanStartTime = defaultStartTime;
        }
    }

    private string GetSessionLabel(Hanchan session)
    {
        var ordered = hanchansOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero).ToList();
        var index = ordered.IndexOf(session) + 1;
        var timeStr = session.StartTime.HasValue
            ? session.StartTime.Value.ToString(@"hh\:mm")
            : Lang.Get("NoTime");

        if (hanchansOnDate.Count > 1)
            return $"#{index} — {timeStr}";
        return timeStr;
    }

    private string GetCurrentHanchanHeader()
    {
        var ordered = hanchansOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero).ToList();
        var index = currentHanchan != null ? ordered.IndexOf(currentHanchan) + 1 : ordered.Count + 1;
        var timeStr = hanchanStartTime.HasValue
            ? hanchanStartTime.Value.ToString(@"hh\:mm")
            : "";

        var header = $"{index}";
        if (timeStr.Length > 0)
            header += $" {timeStr}";
        return header;
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            sessionDate = date;
            await LoadSessionsForDate();
        }
    }

    private void OnHourChanged(ChangeEventArgs e)
    {
        if (IsLockedPastSession) return;
        if (int.TryParse(e.Value?.ToString(), out var h) && h >= 0)
        {
            var currentMinute = hanchanStartTime?.Minutes ?? 0;
            hanchanStartTime = new TimeSpan(h, currentMinute, 0);
        }
        else
        {
            hanchanStartTime = defaultStartTime;
        }
    }

    private void OnMinuteChanged(ChangeEventArgs e)
    {
        if (IsLockedPastSession) return;
        if (int.TryParse(e.Value?.ToString(), out var m) && m >= 0)
        {
            var currentHour = hanchanStartTime?.Hours ?? 0;
            hanchanStartTime = new TimeSpan(currentHour, m, 0);
        }
        else
        {
            hanchanStartTime = defaultStartTime;
        }
    }

    private void ToggleAttendance(Guid memberId, bool isPresent)
    {
        if (IsLockedPastSession) return;

        if (isPresent)
            presentIds.Add(memberId);
        else
            presentIds.Remove(memberId);
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;
    }

    private void SelectAll()
    {
        if (IsLockedPastSession) return;

        presentIds = new HashSet<Guid>(activeMembers.Select(m => m.Id));
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;
    }

    private void SelectNone()
    {
        if (IsLockedPastSession) return;

        presentIds.Clear();
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;
    }

    private async Task GenerateTables()
    {
        if (IsLockedPastSession) return;

        if (tables.Count > 0 && currentHanchan is { IsFinalized: true })
        {
            showRegenerateConfirm = true;
            return;
        }

        await DoGenerateTables();
    }

    private async Task ConfirmRegenerate()
    {
        showRegenerateConfirm = false;
        await DoGenerateTables();
    }

    private void CancelRegenerate()
    {
        showRegenerateConfirm = false;
    }

    private async Task DoGenerateTables()
    {
        tables = await TableAssignmentService.AssignTables(presentIds.ToList());
        saved = false;
    }

    private void AppendTablesHtml(System.Text.StringBuilder html, System.Text.StringBuilder text, List<TableAssignment> tablesToRender)
    {
        html.Append("<div style=\"overflow:hidden;\">");

        for (int i = 0; i < tablesToRender.Count; i++)
        {
            var table = tablesToRender[i];
            var is3 = table.PlayerCount == 3;
            var headerBg = is3 ? "#ffc107" : "#198754";
            var headerColor = is3 ? "#000" : "#fff";
            var borderColor = is3 ? "#ffc107" : "#198754";

            html.Append($"<div class=\"table-block\" style=\"float:left;width:31.5%;margin:0 0.9% 14px;\">");
            html.Append($"<div style=\"border:1px solid {borderColor};border-radius:4px;overflow:hidden;font-family:Verdana,sans-serif;font-size:13px;\">");
            html.Append($"<div style=\"background:{headerBg};color:{headerColor};padding:4px 8px;font-weight:bold;white-space:nowrap;\">");
            html.Append($"{Lang.Get("Table")} {table.TableNumber} ({table.PlayerCount} {Lang.Get("players")})");
            html.Append("</div>");

            text.AppendLine($"*{Lang.Get("Table")} {table.TableNumber}* ({table.PlayerCount} {Lang.Get("players")})");

            foreach (var playerId in table.PlayerIds)
            {
                var name = GetPlayerName(playerId);
                html.Append($"<div style=\"padding:3px 8px;border-top:1px solid #dee2e6;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">{name}</div>");
                text.AppendLine($"  {name}");
            }

            html.Append("</div></div>");

            if (i + 1 < tablesToRender.Count)
                text.AppendLine();
        }

        html.Append("</div>");
    }

    private (string html, string text) BuildSingleHanchanContent()
    {
        var ordered = hanchansOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero).ToList();
        var hanchanNumber = currentHanchan != null
            ? ordered.IndexOf(currentHanchan) + 1
            : ordered.Count + 1;
        var timeStr = hanchanStartTime.HasValue ? hanchanStartTime.Value.ToString(@"hh\:mm") : "";
        var dateText = Lang.FormatDate(sessionDate);
        var hanchanText = $"{Lang.Get("Hanchan")} {hanchanNumber}";
        if (timeStr.Length > 0)
            hanchanText += $" {timeStr}";

        var html = new System.Text.StringBuilder();
        var text = new System.Text.StringBuilder();

        html.Append($"<div style=\"font-family:Verdana,sans-serif;font-size:14px;font-weight:bold;margin-bottom:4px;\">{dateText}</div>");
        html.Append($"<div style=\"font-family:Verdana,sans-serif;font-size:14px;font-weight:bold;margin-bottom:14px;\">{hanchanText}</div>");
        text.AppendLine($"*{dateText}*");
        text.AppendLine($"*{hanchanText}*");
        text.AppendLine();

        AppendTablesHtml(html, text, tables);

        return (html.ToString(), text.ToString().TrimEnd());
    }

    private (string html, string text) BuildAllHanchansContent()
    {
        var orderedHanchans = hanchansOnDate
            .Where(s => s.Tables.Count > 0)
            .OrderBy(s => s.StartTime ?? TimeSpan.Zero)
            .ToList();

        var html = new System.Text.StringBuilder();
        var text = new System.Text.StringBuilder();

        var dateHeader = Lang.FormatDate(sessionDate);
        html.Append($"<div style=\"font-family:Verdana,sans-serif;font-size:14px;font-weight:bold;margin-bottom:8px;\">{dateHeader}</div>");
        text.AppendLine($"*{dateHeader}*");
        text.AppendLine();

        for (int hi = 0; hi < orderedHanchans.Count; hi++)
        {
            var hanchan = orderedHanchans[hi];
            var hanchanIndex = hi + 1;
            var timeStr = hanchan.StartTime.HasValue ? hanchan.StartTime.Value.ToString(@"hh\:mm") : "";
            var hanchanHeader = $"{Lang.Get("Hanchan")} {hanchanIndex}";
            if (timeStr.Length > 0)
                hanchanHeader += $" {timeStr}";

            html.Append("<div style=\"break-inside:avoid;page-break-inside:avoid;\">");
            html.Append($"<div style=\"font-family:Verdana,sans-serif;font-size:14px;font-weight:bold;margin:12px 0 14px;\">{hanchanHeader}</div>");
            text.AppendLine($"*{hanchanHeader}*");

            AppendTablesHtml(html, text, hanchan.Tables);
            html.Append("</div>");
            text.AppendLine();
        }

        return (html.ToString(), text.ToString().TrimEnd());
    }

    private string WrapAsHtmlDocument(string title, string bodyContent, bool includePrintButton = false)
    {
        var printBtn = includePrintButton
            ? "<div class=\"no-print\"><button onclick=\"window.print()\" style=\"padding:8px 20px;font-size:16px;cursor:pointer;\">Print</button></div>"
            : "";
        return "<!DOCTYPE html><html><head><meta charset=\"utf-8\">" +
               "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">" +
               $"<title>{title}</title>" +
               "<style>" +
               "body { font-family: Verdana, Arial, sans-serif; margin: 0; padding: 2px; } " +
               ".no-print { position:sticky;top:0;z-index:100;padding:8px;margin-bottom:6px;background:#f0f0f0;border-bottom:1px solid #ccc; } " +
               "@media screen and (max-width:600px) { .table-block { float:none !important;width:100% !important;margin:0 0 10px !important; } } " +
               "@media print { .no-print { display:none; } body { padding:0; } }" +
               "</style></head><body>" +
               printBtn + bodyContent + "</body></html>";
    }

