@page "/session"
@using Tsump.Models
@using Tsump.Services
@inject MemberService MemberService
@inject SessionService SessionService
@inject TableAssignmentService TableAssignmentService
@inject LanguageService Lang
@inject SettingsService SettingsService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@Lang.Get("WeeklySession") - Tsumo!</PageTitle>

<h1>@Lang.Get("WeeklySession")</h1>

<div class="row mb-3">
    <div class="col-auto">
        <label class="form-label"><strong>@Lang.Get("SessionDate")</strong></label>
        <input type="date" class="form-control" style="max-width: 250px;"
               value="@sessionDate.ToString("yyyy-MM-dd")"
               @onchange="OnDateChanged" />
    </div>
    <div class="col-auto">
        <label class="form-label"><strong>@Lang.Get("StartTime")</strong></label>
        <div class="d-flex align-items-center gap-1">
            <select class="form-select" style="max-width: 75px;"
                    value="@(sessionStartTime.HasValue ? sessionStartTime.Value.Hours : -1)"
                    disabled="@IsLockedPastSession"
                    @onchange="OnHourChanged">
                <option value="-1">--</option>
                @for (int h = 0; h < 24; h++)
                {
                    var hh = h;
                    <option value="@hh">@hh.ToString("D2")</option>
                }
            </select>
            <span>:</span>
            <select class="form-select" style="max-width: 75px;"
                    value="@(sessionStartTime.HasValue ? sessionStartTime.Value.Minutes : -1)"
                    disabled="@IsLockedPastSession"
                    @onchange="OnMinuteChanged">
                <option value="-1">--</option>
                @for (int m = 0; m < 60; m += 5)
                {
                    var mm = m;
                    <option value="@mm">@mm.ToString("D2")</option>
                }
            </select>
        </div>
    </div>
</div>

@if (sessionsOnDate.Count > 0)
{
    <div class="mb-3">
        <label class="form-label"><strong>@Lang.Get("SessionsOnDate")</strong></label>
        <div class="btn-group d-block" role="group">
            @foreach (var s in sessionsOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero))
            {
                var isActive = currentSession?.Id == s.Id;
                var sessionLabel = GetSessionLabel(s);
                <button class="btn btn-sm me-1 mb-1 @(isActive ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SelectSession(s)">
                    @sessionLabel
                </button>
            }
            <button class="btn btn-sm btn-outline-success me-1 mb-1" @onclick="StartNewSession"
                    disabled="@(currentSession != null && !currentSession.IsFinalized)">
                + @Lang.Get("NewSession")
            </button>
        </div>
    </div>
}

@if (IsLockedPastSession)
{
    <div class="alert alert-warning">
        @Lang.Get("PastSessionReadOnly")
    </div>
}

@if (members == null)
{
    <p>@Lang.Get("Loading")</p>
}
else if (members.Count == 0)
{
    <p class="text-muted">@Lang.Get("NoMembersRegistered") <a href="members">@Lang.Get("AddMembersLink")</a>.</p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@Lang.Get("Attendance") (@presentIds.Count @Lang.Get("present") @Lang.Get("of") @activeMembers.Count @Lang.Get("active"))</h5>
            @if (!IsLockedPastSession)
            {
                <div class="mb-2">
                    <button class="btn btn-sm btn-outline-success me-1" @onclick="SelectAll">@Lang.Get("AllPresent")</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="SelectNone">@Lang.Get("AllAbsent")</button>
                </div>
            }
            <div class="mb-3">
                <input type="text" class="form-control" placeholder="@Lang.Get("SearchMembers")"
                       style="max-width: 300px; border-radius: 15px;"
                       @bind="searchText" @bind:event="oninput" />
            </div>
            <div class="row">
                @foreach (var member in FilteredMembers())
                {
                    <div class="col-md-4 col-sm-6 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   checked="@presentIds.Contains(member.Id)"
                                   disabled="@IsLockedPastSession"
                                   @onchange="e => ToggleAttendance(member.Id, (bool)(e.Value ?? false))" />
                            <label class="form-check-label">@member.Name</label>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (!IsLockedPastSession)
    {
        <div class="mb-3">
            @if (showRegenerateConfirm)
            {
                <div class="alert alert-warning d-inline-block me-2">
                    @Lang.Get("RegenerateConfirm")
                    <button class="btn btn-sm btn-warning ms-2 me-1" @onclick="ConfirmRegenerate">@Lang.Get("YesRegenerate")</button>
                    <button class="btn btn-sm btn-secondary" @onclick="CancelRegenerate">@Lang.Get("Cancel")</button>
                </div>
            }
            else
            {
                <button class="btn btn-primary me-2" @onclick="GenerateTables" disabled="@(presentIds.Count < 3)">
                    @Lang.Get("GenerateTableAssignments")
                </button>
            }
            <button class="btn btn-success" @onclick="SaveSession" disabled="@(tables.Count == 0)">
                @Lang.Get("SaveSession")
            </button>
            @if (currentSession != null)
            {
                @if (showDeleteConfirm)
                {
                    <span class="alert alert-danger d-inline-block ms-2 mb-0 py-1">
                        @Lang.Get("DeleteSessionConfirm")
                        <button class="btn btn-sm btn-danger ms-2 me-1" @onclick="ConfirmDeleteSession">@Lang.Get("YesDelete")</button>
                        <button class="btn btn-sm btn-secondary" @onclick="CancelDeleteSession">@Lang.Get("Cancel")</button>
                    </span>
                }
                else
                {
                    <button class="btn btn-outline-danger ms-2" @onclick="RequestDeleteSession">
                        @Lang.Get("DeleteSession")
                    </button>
                }
            }
            @if (presentIds.Count < 3)
            {
                <span class="text-warning ms-2">@Lang.Get("NeedAtLeast3")</span>
            }
        </div>
    }

    @if (IsLockedPastSession && currentSession != null)
    {
        <div class="mb-3">
            @if (showDeleteConfirm)
            {
                <div class="alert alert-danger d-inline-block">
                    @Lang.Get("DeleteSessionConfirm")
                    <button class="btn btn-sm btn-danger ms-2 me-1" @onclick="ConfirmDeleteSession">@Lang.Get("YesDelete")</button>
                    <button class="btn btn-sm btn-secondary" @onclick="CancelDeleteSession">@Lang.Get("Cancel")</button>
                </div>
            }
            else
            {
                <button class="btn btn-outline-danger" @onclick="RequestDeleteSession">
                    @Lang.Get("DeleteSession")
                </button>
            }
        </div>
    }

    @if (tables.Count > 0)
    {
        <div class="d-flex align-items-center mb-2">
            <h4 class="mb-0">@Lang.Get("TableAssignments")</h4>
            <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="CopyTablesToClipboard">
                @(copiedToClipboard ? Lang.Get("Copied") : Lang.Get("CopyToClipboard"))
            </button>
        </div>

        @if (!IsLockedPastSession && selectedPlayerIds.Count > 0)
        {
            <div class="mb-3">
                <span class="text-muted me-2">
                    @Lang.Get("Selected"): @string.Join(", ", selectedPlayerIds.Select(id => GetPlayerName(id)))
                </span>
                @if (selectedPlayerIds.Count == 2)
                {
                    <button class="btn btn-sm btn-warning me-1" @onclick="SwapSelectedPlayers">
                        @Lang.Get("SwapPlayers")
                    </button>
                }
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearSelection">
                    @Lang.Get("ClearSelection")
                </button>
            </div>
        }

        <div class="row">
            @foreach (var table in tables)
            {
                <div class="col-md-4 mb-3">
                    <div class="card @(table.PlayerCount == 3 ? "border-warning" : "border-success")">
                        <div class="card-header @(table.PlayerCount == 3 ? "bg-warning text-dark" : "bg-success text-white")">
                            @Lang.Get("Table") @table.TableNumber (@table.PlayerCount @Lang.Get("players"))
                        </div>
                        <ul class="list-group list-group-flush">
                            @foreach (var playerId in table.PlayerIds)
                            {
                                var pid = playerId;
                                var player = members.FirstOrDefault(m => m.Id == pid);
                                var isSelected = selectedPlayerIds.Contains(pid);
                                <li class="list-group-item d-flex align-items-center @(isSelected ? "list-group-item-primary" : "")"
                                    style="cursor: @(IsLockedPastSession ? "default" : "grab")"
                                    draggable="@(!IsLockedPastSession)"
                                    @ondragstart="() => OnDragStart(pid)"
                                    @ondragover:preventDefault
                                    @ondrop="() => OnDrop(pid)"
                                    @onclick="() => OnPlayerClick(pid)">
                                    <span>@(player?.Name ?? Lang.Get("Unknown"))</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

        @if (presentIds.Count - tables.Sum(t => t.PlayerCount) > 0)
        {
            <div class="alert alert-info">
                @(presentIds.Count - tables.Sum(t => t.PlayerCount)) @Lang.Get("UnassignedPlayers")
            </div>
        }
    }

    @if (saved)
    {
        <div class="alert alert-success mt-3">@Lang.Get("SessionSaved")</div>
    }
}

@code {
    private List<Member>? members;
    private List<Member> activeMembers = new();
    private HashSet<Guid> presentIds = new();
    private List<TableAssignment> tables = new();
    private DateTime sessionDate = DateTime.Today;
    private TimeSpan? sessionStartTime;
    private bool saved;
    private string searchText = string.Empty;
    private bool showRegenerateConfirm;
    private bool showDeleteConfirm;

    private List<WeeklySession> sessionsOnDate = new();
    private WeeklySession? currentSession;

    private List<Guid> selectedPlayerIds = new();
    private Guid? draggedPlayerId;
    private bool copiedToClipboard;

    private bool IsLockedPastSession =>
        sessionDate.Date < DateTime.Today && currentSession is { IsFinalized: true };

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;

    private IEnumerable<Member> FilteredMembers()
    {
        var ordered = activeMembers.OrderBy(m => m.Name);
        if (string.IsNullOrWhiteSpace(searchText))
            return ordered;
        return ordered.Where(m => m.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            members = await MemberService.GetAllAsync();
            activeMembers = members.Where(m => m.IsActive).ToList();

            // Auto-set date/time to next scheduled slot if no session exists for today
            var nextSlot = await SettingsService.GetNextScheduledSlotAsync();
            if (nextSlot != null)
            {
                sessionDate = nextSlot.Value.Date;
                sessionStartTime = nextSlot.Value.Time;
            }

            await LoadSessionsForDate();
            StateHasChanged();
        }
    }

    private async Task LoadSessionsForDate()
    {
        var allSessions = await SessionService.GetAllAsync();
        sessionsOnDate = allSessions.Where(s => s.Date.Date == sessionDate.Date).ToList();

        if (sessionsOnDate.Count > 0)
        {
            // Select the first session (by time) by default
            var first = sessionsOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero).First();
            LoadFromSession(first);
        }
        else
        {
            currentSession = null;
            // Preserve sessionStartTime if it was pre-set from the schedule
            if (sessionStartTime == null)
            {
                var settings = await SettingsService.GetAsync();
                var entry = settings.Schedule.FirstOrDefault(e => e.Day == sessionDate.DayOfWeek);
                if (entry != null && entry.StartTimes.Count > 0)
                    sessionStartTime = entry.StartTimes.OrderBy(t => t).First();
            }
            presentIds.Clear();
            tables.Clear();
        }
        saved = false;
        showRegenerateConfirm = false;
    }

    private void LoadFromSession(WeeklySession session)
    {
        currentSession = session;
        sessionStartTime = session.StartTime;
        presentIds = new HashSet<Guid>(session.PresentMemberIds);
        tables = session.Tables;
        saved = false;
        showRegenerateConfirm = false;
    }

    private void SelectSession(WeeklySession session)
    {
        LoadFromSession(session);
    }

    private async Task StartNewSession()
    {
        // Copy attendance from the last session on this date
        var lastSession = sessionsOnDate
            .OrderByDescending(s => s.StartTime ?? TimeSpan.Zero)
            .FirstOrDefault();
        if (lastSession != null)
            presentIds = new HashSet<Guid>(lastSession.PresentMemberIds);
        else
            presentIds.Clear();

        currentSession = null;
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;

        // Set start time to next available time on this date from the schedule
        var settings = await SettingsService.GetAsync();
        var entry = settings.Schedule.FirstOrDefault(e => e.Day == sessionDate.DayOfWeek);
        if (entry != null && entry.StartTimes.Count > 0)
        {
            var usedTimes = sessionsOnDate.Select(s => s.StartTime).Where(t => t.HasValue).Select(t => t!.Value).ToHashSet();
            var nextTime = entry.StartTimes.OrderBy(t => t).FirstOrDefault(t => !usedTimes.Contains(t));
            sessionStartTime = nextTime != default ? nextTime : null;
        }
        else
        {
            sessionStartTime = null;
        }
    }

    private string GetSessionLabel(WeeklySession session)
    {
        var ordered = sessionsOnDate.OrderBy(s => s.StartTime ?? TimeSpan.Zero).ToList();
        var index = ordered.IndexOf(session) + 1;
        var timeStr = session.StartTime.HasValue
            ? session.StartTime.Value.ToString(@"hh\:mm")
            : Lang.Get("NoTime");

        if (sessionsOnDate.Count > 1)
            return $"#{index} — {timeStr}";
        return timeStr;
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            sessionDate = date;
            await LoadSessionsForDate();
        }
    }

    private void OnHourChanged(ChangeEventArgs e)
    {
        if (IsLockedPastSession) return;
        if (int.TryParse(e.Value?.ToString(), out var h) && h >= 0)
        {
            var currentMinute = sessionStartTime?.Minutes ?? 0;
            sessionStartTime = new TimeSpan(h, currentMinute, 0);
        }
        else
        {
            sessionStartTime = null;
        }
    }

    private void OnMinuteChanged(ChangeEventArgs e)
    {
        if (IsLockedPastSession) return;
        if (int.TryParse(e.Value?.ToString(), out var m) && m >= 0)
        {
            var currentHour = sessionStartTime?.Hours ?? 0;
            sessionStartTime = new TimeSpan(currentHour, m, 0);
        }
        else
        {
            sessionStartTime = null;
        }
    }

    private void ToggleAttendance(Guid memberId, bool isPresent)
    {
        if (IsLockedPastSession) return;

        if (isPresent)
            presentIds.Add(memberId);
        else
            presentIds.Remove(memberId);
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;
    }

    private void SelectAll()
    {
        if (IsLockedPastSession) return;

        presentIds = new HashSet<Guid>(activeMembers.Select(m => m.Id));
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;
    }

    private void SelectNone()
    {
        if (IsLockedPastSession) return;

        presentIds.Clear();
        tables.Clear();
        saved = false;
        showRegenerateConfirm = false;
    }

    private async Task GenerateTables()
    {
        if (IsLockedPastSession) return;

        if (tables.Count > 0 && currentSession is { IsFinalized: true })
        {
            showRegenerateConfirm = true;
            return;
        }

        await DoGenerateTables();
    }

    private async Task ConfirmRegenerate()
    {
        showRegenerateConfirm = false;
        await DoGenerateTables();
    }

    private void CancelRegenerate()
    {
        showRegenerateConfirm = false;
    }

    private async Task DoGenerateTables()
    {
        tables = await TableAssignmentService.AssignTables(presentIds.ToList());
        saved = false;
    }

    private async Task CopyTablesToClipboard()
    {
        if (tables.Count == 0 || members == null) return;

        // Build HTML version
        var html = new System.Text.StringBuilder();
        html.Append("<table style=\"border-collapse:separate;border-spacing:12px 0;\"><tr>");

        for (int i = 0; i < tables.Count; i++)
        {
            if (i > 0 && i % 2 == 0)
                html.Append("</tr><tr style=\"height:8px;\"><td></td></tr><tr>");

            var table = tables[i];
            var is3 = table.PlayerCount == 3;
            var headerBg = is3 ? "#ffc107" : "#198754";
            var headerColor = is3 ? "#000" : "#fff";
            var borderColor = is3 ? "#ffc107" : "#198754";

            html.Append($"<td style=\"vertical-align:top;width:200px;padding:0 4px;\">");
            html.Append($"<div style=\"border:1px solid {borderColor};border-radius:4px;overflow:hidden;font-family:Verdana,sans-serif;font-size:13px;\">");
            html.Append($"<div style=\"background:{headerBg};color:{headerColor};padding:6px 10px;font-weight:bold;\">");
            html.Append($"{Lang.Get("Table")} {table.TableNumber} ({table.PlayerCount} {Lang.Get("players")})");
            html.Append("</div>");

            foreach (var playerId in table.PlayerIds)
            {
                var name = GetPlayerName(playerId);
                html.Append($"<div style=\"padding:4px 10px;border-top:1px solid #dee2e6;\">{name}</div>");
            }

            html.Append("</div></td>");
        }

        html.Append("</tr></table>");

        // Build plain text version (single column, works in proportional fonts like WhatsApp)
        var text = new System.Text.StringBuilder();

        for (int i = 0; i < tables.Count; i++)
        {
            var table = tables[i];
            text.AppendLine($"*{Lang.Get("Table")} {table.TableNumber}* ({table.PlayerCount} {Lang.Get("players")})");

            foreach (var playerId in table.PlayerIds)
            {
                text.AppendLine($"  {GetPlayerName(playerId)}");
            }

            if (i + 1 < tables.Count)
                text.AppendLine();
        }

        await JS.InvokeVoidAsync("copyToClipboard", html.ToString(), text.ToString().TrimEnd());
        copiedToClipboard = true;
        _ = ResetCopiedFlag();
    }

    private async Task ResetCopiedFlag()
    {
        await Task.Delay(2000);
        copiedToClipboard = false;
        StateHasChanged();
    }

    private string GetPlayerName(Guid id)
    {
        return members?.FirstOrDefault(m => m.Id == id)?.Name ?? Lang.Get("Unknown");
    }

    private void OnPlayerClick(Guid playerId)
    {
        if (IsLockedPastSession) return;

        if (selectedPlayerIds.Contains(playerId))
        {
            selectedPlayerIds.Remove(playerId);
        }
        else if (selectedPlayerIds.Count < 2)
        {
            selectedPlayerIds.Add(playerId);
            if (selectedPlayerIds.Count == 2)
                return; // wait for swap button click
        }
        else
        {
            // Already 2 selected — replace the second one
            selectedPlayerIds[1] = playerId;
        }
    }

    private void SwapSelectedPlayers()
    {
        if (selectedPlayerIds.Count != 2) return;
        SwapPlayers(selectedPlayerIds[0], selectedPlayerIds[1]);
        selectedPlayerIds.Clear();
    }

    private void ClearSelection()
    {
        selectedPlayerIds.Clear();
    }

    private void OnDragStart(Guid playerId)
    {
        if (IsLockedPastSession) return;
        draggedPlayerId = playerId;
    }

    private void OnDrop(Guid targetPlayerId)
    {
        if (IsLockedPastSession || draggedPlayerId == null || draggedPlayerId == targetPlayerId) return;
        SwapPlayers(draggedPlayerId.Value, targetPlayerId);
        draggedPlayerId = null;
        selectedPlayerIds.Clear();
    }

    private void SwapPlayers(Guid playerA, Guid playerB)
    {
        TableAssignment? tableA = null, tableB = null;
        int indexA = -1, indexB = -1;

        foreach (var table in tables)
        {
            var idxA = table.PlayerIds.IndexOf(playerA);
            if (idxA >= 0) { tableA = table; indexA = idxA; }

            var idxB = table.PlayerIds.IndexOf(playerB);
            if (idxB >= 0) { tableB = table; indexB = idxB; }
        }

        if (tableA == null || tableB == null) return;

        tableA.PlayerIds[indexA] = playerB;
        tableB.PlayerIds[indexB] = playerA;
        saved = false;
    }

    private void RequestDeleteSession()
    {
        showDeleteConfirm = true;
    }

    private void CancelDeleteSession()
    {
        showDeleteConfirm = false;
    }

    private async Task ConfirmDeleteSession()
    {
        if (currentSession == null) return;

        await SessionService.DeleteAsync(currentSession.Id);
        showDeleteConfirm = false;
        await LoadSessionsForDate();
    }

    private async Task SaveSession()
    {
        if (IsLockedPastSession) return;

        var session = new WeeklySession
        {
            Date = sessionDate,
            StartTime = sessionStartTime,
            PresentMemberIds = presentIds.ToList(),
            AbsentMemberIds = activeMembers
                .Where(m => !presentIds.Contains(m.Id))
                .Select(m => m.Id)
                .ToList(),
            Tables = tables,
            IsFinalized = true
        };

        if (currentSession != null)
            session.Id = currentSession.Id;

        await SessionService.SaveAsync(session);
        currentSession = session;

        // Refresh the session list for this date
        var allSessions = await SessionService.GetAllAsync();
        sessionsOnDate = allSessions.Where(s => s.Date.Date == sessionDate.Date).ToList();

        saved = true;
    }
}
