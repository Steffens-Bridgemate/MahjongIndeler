@page "/tournaments"
@using Tsump.Models
@using Tsump.Services
@inject TournamentService TournamentService
@inject LanguageService Lang
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@Lang.Get("Tournaments") - Tsumo!</PageTitle>

<h1>@Lang.Get("Tournaments")</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowCreateForm">@Lang.Get("CreateTournament")</button>
</div>

@if (showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@Lang.Get("CreateTournament")</h5>
            <div class="mb-3">
                <label class="form-label">@Lang.Get("TournamentName")</label>
                <input class="form-control" @bind="newName" />
            </div>
            <div class="mb-3">
                <label class="form-label">@Lang.Get("TournamentDate")</label>
                <input type="date" class="form-control" @bind="newDate" />
            </div>
            <div class="mb-3">
                <label class="form-label">@Lang.Get("NumberOfSessions")</label>
                <select class="form-select" style="max-width: 120px;" @bind="newSessionCount">
                    @for (int i = 3; i <= 8; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>
            <button class="btn btn-success me-2" @onclick="CreateTournament">@Lang.Get("Save")</button>
            <button class="btn btn-secondary" @onclick="() => showForm = false">@Lang.Get("Cancel")</button>
        </div>
    </div>
}

@if (tournaments == null)
{
    <p>@Lang.Get("Loading")</p>
}
else if (tournaments.Count == 0)
{
    <p class="text-muted">@Lang.Get("NoTournamentsYet")</p>
}
else
{
    <div class="row">
        @foreach (var t in tournaments.OrderByDescending(x => x.Date))
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@t.Name</h5>
                        <p class="card-text text-muted">
                            @Lang.FormatDate(t.Date) &middot;
                            @t.Participants.Count @Lang.Get("ParticipantCount") &middot;
                            @t.SessionCount @Lang.Get("SessionsCount")
                            @if (t.IsGenerated)
                            {
                                <span class="badge bg-success ms-2">&#10003;</span>
                            }
                        </p>
                        <button class="btn btn-primary btn-sm me-2" @onclick="() => OpenTournament(t.Id)">
                            @Lang.Get("OpenTournament")
                        </button>
                        @if (deleteConfirmId == t.Id)
                        {
                            <span class="text-danger me-2">@Lang.Get("DeleteTournamentConfirm")</span>
                            <button class="btn btn-danger btn-sm me-1" @onclick="() => ConfirmDelete(t.Id)">@Lang.Get("YesDelete")</button>
                            <button class="btn btn-secondary btn-sm" @onclick="() => deleteConfirmId = null">@Lang.Get("Cancel")</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => deleteConfirmId = t.Id">@Lang.Get("Remove")</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Tournament>? tournaments;
    private bool showForm;
    private string newName = string.Empty;
    private DateTime newDate = DateTime.Today;
    private int newSessionCount = 4;
    private Guid? deleteConfirmId;

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            tournaments = await TournamentService.GetAllAsync();
            StateHasChanged();
        }
    }

    private void ShowCreateForm()
    {
        newName = string.Empty;
        newDate = DateTime.Today;
        newSessionCount = 4;
        showForm = true;
    }

    private async Task CreateTournament()
    {
        if (string.IsNullOrWhiteSpace(newName))
            return;

        var tournament = new Tournament
        {
            Name = newName,
            Date = newDate,
            SessionCount = newSessionCount
        };

        await TournamentService.SaveAsync(tournament);
        tournaments = await TournamentService.GetAllAsync();
        showForm = false;

        Nav.NavigateTo($"tournament/{tournament.Id}");
    }

    private void OpenTournament(Guid id)
    {
        Nav.NavigateTo($"tournament/{id}");
    }

    private async Task ConfirmDelete(Guid id)
    {
        await TournamentService.DeleteAsync(id);
        tournaments = await TournamentService.GetAllAsync();
        deleteConfirmId = null;
    }
}
